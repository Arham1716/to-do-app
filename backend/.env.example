# Copy to .env and adjust. Used when running backend locally (not in Docker).
# When running in Docker, these are set by docker-compose.

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=user
DB_PASSWORD=password
DB_NAME=todo

# Optional: CORS allowed origins. "*" = any, or comma-separated (e.g. http://192.168.1.100:3000)
# CORS_ORIGIN=*
